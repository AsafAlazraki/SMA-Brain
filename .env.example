# All values ship EMPTY on purpose: an empty var means "not configured" and the app
# falls back to zero-key mock mode. Example values live in the comments — never as
# real-looking placeholders, which would silently defeat mock mode after `cp`.

# ── Supabase ─────────────────────────────────────────────
VITE_SUPABASE_URL=                         # e.g. http://127.0.0.1:54321 (from `supabase start`)
VITE_SUPABASE_ANON_KEY=                    # anon key — safe for client
SUPABASE_SERVICE_ROLE_KEY=                 # server-only (Netlify env), NEVER in client bundle
SUPABASE_DB_URL=                           # postgresql://... — for scripts/migrations only

# ── Anthropic (the brain) ────────────────────────────────
ANTHROPIC_API_KEY=                         # sk-ant-... ; leave empty for mock mode
ANTHROPIC_MODEL=                           # big model for user-facing answers/drafts (pin at build)
ANTHROPIC_MODEL_FAST=                      # small fast model for rewrite/distill/tag/repair
MOCK_LLM=                                  # set "true" to force canned streaming even with keys set

# ── Embeddings ───────────────────────────────────────────
EMBEDDINGS_PROVIDER=                       # voyage | openai  (bake-off at S3)
EMBEDDINGS_MODEL=                          # pinned model id, 768-d
VOYAGE_API_KEY=
OPENAI_API_KEY=                            # only if EMBEDDINGS_PROVIDER=openai

# ── Voice (per docs/05-voice-architecture.md) ────────────
STT_PROVIDER=                              # deepgram | assemblyai | speechmatics (bake-off at S8)
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
SPEECHMATICS_API_KEY=
TTS_PROVIDER=                              # elevenlabs | cartesia | ...
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CARTESIA_API_KEY=
LIVEKIT_URL=                               # wss://... (if LiveKit stack selected)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── App ──────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8888
PUBLIC_BOT_ENABLED=false                   # Phase 2 flag; also mirrored in app_settings

# ── Seed accounts (npm run seed:users) ───────────────────
# Invite-only system: these create the first admin + staff logins.
# Local-dev defaults exist (tony@sma.local / staff@sma.local); the script REFUSES
# the committed default passwords against anything that isn't 127.0.0.1/localhost.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_STAFF_EMAIL=
SEED_STAFF_PASSWORD=
SEED_STAFF_NAME=
